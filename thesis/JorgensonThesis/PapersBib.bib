@ARTICLE{Palmer1998b,
  author = {C Palmer},
  title = {'Following the plough': the agricultural environment of Northern
	Jordan},
  journal = {Levant(London)},
  year = {1998},
  volume = {30},
  pages = {129--165},
  abstract = {This paper documents disappearing agricultural practices in northern
	Jordan. The fieldwork for the study was conducted between 1989 and
	1992. The paper sets out the local classification of crops and the
	main events of the agricultural year. It includes a discussion of
	traditional measures for seed and land. Tillage is central to good
	crop management practices and the ard, or scratch-plough, is also
	discussed. Changes in agricultural practice, as described by the
