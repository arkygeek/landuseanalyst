@ARTICLE{Evershed1993,
  author = {R Evershed},
  title = {Biomolecular Archaeology and Lipids},
  journal = {World archaeology},
  year = {1993},
  volume = {25},
  pages = {74--93},
  number = {1},
  month = {Jun},
  note = {Biomolecular Archaeology},
  abstract = {Medium-sized biomolecules, particularly lipids, can frequently be
	detected in ancient materials. The structures and compositions of
	mixtures of lipids can provide direct evidence for their origin,
	and hence, evidence for human activity in the past. An important
	concept in the field of biomolecular archaeology of lipids is that
	of 'biomarkers'. Archaeological biomarkers are characteristic compounds
	(or mixtures of compounds) found in archaeological materials that
	can be matched to those present in contemporary materials likely
	to have been exploited in antiquity. Some of the general principles
	surrounding the use of lipid biomarkers, including their properties,
	origins, means of detection, characterization, modes of preservation
	and decay, and application to archaeological investigation, are discussed
	in this article. Examples are presented to illustrate the scope of
	the biomolecular archaeology of lipids and some remarks are made
	concerning possible areas of future development.},
  date-added = {2009-03-04 16:22:14 +0000},
