@ARTICLE{David2008,
  author = {I David and J M Astruc and G Lagriffoul and E Manfredi and C Robert-Granie
	and L Bodin},
  title = {Genetic Correlation Between Female Fertility and Milk Yield in Lacaune
	Sheep},
  journal = {J. Dairy Sci.},
  year = {2008},
  volume = {91},
  pages = {4047--4052},
  number = {10},
  abstract = {A total of 416,670 lactations for 189,101 ewes from 3,603 sires and
	distributed across 1,978 herd-year groups were used to estimate genetic
	and environmental parameters of standardized milk yield (SMYT), fertility
	in ewe lambs (PR1), and fertility in adult ewes (PRA). Parameters
	were estimated with a multiple-trait sire linear model. Heritabilities
	for SMYT, PR1, and PRA were 0.27 (0.009), 0.04 (0.004), and 0.05
	(0.004), respectively. These results were in accordance with the
	literature. The genetic correlation between PR1 and PRA was 0.55,
	indicating that fertility is not the same trait in ewe lambs and
	adult ewes. The genetic correlation between milk yield and lamb fertility
	was not significantly different from zero. The genetic correlation
	between milk yield and fertility in adult ewe (-0.23) was in the
	range of antagonistic correlations reported in dairy cattle. Consequently,
	these results show that selection for milk yield can induce an indirect
	decrease in fertility. Nevertheless, no phenotypic decrease in fertility
	in artificial insemination matings has been observed in this population.
	This is the first time that correlation between milk yield and fertility
	is reported in sheep and further investigations are needed to confirm
	this result.},
  date-added = {2009-03-04 16:22:14 +0000},
  date-modified = {2009-03-04 16:22:16 +0000},
  doi = {10.3168/jds.2008-1113},
