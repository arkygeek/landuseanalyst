	Number = {2},
	Owner = {arkygeek},
	Pages = {295-311},
	Publisher = {Blackwell Publishing on behalf of the American Anthropological Association},
	Series = {New Series},
	Timestamp = {2009.02.15},
	Title = {Deferred harvests: the transition from hunting to animal husbandry},
	Url = {http://www.jstor.org/stable/683467},
