@article{Boardman1976,
	Abstract = {The physical evidence offered by the palaeobotanist can, in some ancient
	cultures, be supplemented by other information - literary, iconographic
	and archaeological - about plants and trees, the use of their products,
	and their importance in the life, trade and even religion of the
	people who cultivated them. This paper reviews some of the sources
