@article{Higgs1976,
	Abstract = {The history of agriculture is better understood by placing agriculture
	in a broad theoretical framework and in the context of other economies.
	Economies are classified according to the economic niche they occupy.
	The territorial concept is adopted in order to estimate their potential.
	Patterns of exploitation can be seen in the prehistoric record. It
	is believed that in this way we are more able to understand the history
	and the consequences of land and resource utilisation.},
