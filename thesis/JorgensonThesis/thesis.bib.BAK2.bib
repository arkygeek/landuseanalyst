	Publisher = {Society for American Archaeology},
	Timestamp = {2008.11.25},
	Title = {Land-use dynamics and socioeconomic change: an example from the Polop Alto Valley},
	Url = {http://www.jstor.org/stable/2694208},
	Volume = {64},
	Year = {1999},
	Bdsk-Url-1 = {http://www.jstor.org/stable/2694208}}

