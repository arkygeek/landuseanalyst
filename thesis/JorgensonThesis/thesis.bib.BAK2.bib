@article{Holloway1975,
	Abstract = {The excavation of the Early Bronze Age village at Tufariello (Buccinno)
	in southern Italy represents a major archaeological advance in a
	little-known period of Italian prehistory in this region. The emphasis
	of the following report is in the integration of archaeological material,
	especially the statistical study of abundant pottery material from
	three distinct stratigraphic phases of the site, and the discussion
	of the unexpected rectangularly planned buildings of the site, with
	reports on evidence of flora and fauna. The result is the first synthetic
	view of the life of a southern Italian community of the end of the
