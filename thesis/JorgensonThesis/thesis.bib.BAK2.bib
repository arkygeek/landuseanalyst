	Publisher = {The American Schools of Oriental Research},
	Timestamp = {2008.09.22},
	Title = {Settlement, demographic, and economic patterns in the highlands of Palestine in the Chalcolithic and Early Bronze periods and the beginning of urbanism},
	Url = {http://www.jstor.org/stable/1357359},
	Volume = {289},
