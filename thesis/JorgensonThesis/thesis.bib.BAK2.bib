@article{Boyd2006,
	Abstract = {A poorly defined notion of `sedentism' continues to feature prominently
	in archaeological discussions of the Epipalaeolithic/Neolithic transition
	in Levantine prehistory. While acknowledging the valuable contribution
	of previous studies on the subject, this article argues that interpretations
	of the archaeological evidence are being hampered by the continued
	adherence to `sedentism' as a concept for explaining social transformations
	in settlement and landscape, and that there is little more to be
	said from this perspective. I suggest that recent perspectives on
	`social landscapes' will help further our understanding of this period
	in human history. In the specific case of the Later Epipalaeolithic
	(the Natufian and other `cultural entities'), this engagement would
	be profitably grounded in discussion of the histories of human communities'
	perceptions and uses of space, place and landscape, and how these
	perceptions and uses changed over time. It is argued that the Early
	Natufian&#160;-&#160;when, it is claimed, sedentism first appears
	in the Levantine sequence&#160;-&#160;needs to be studied in its
	own right as a particular set of social practices and traditions,
	and not as some kind of `precursor' to the Neolithic almost three
	millennia later.},
	Author = {Boyd, Brian},
	Doi = {doi:10.1080/00438240600688398},
	File = {Boyd2006.pdf:Boyd2006.pdf:PDF},
	Journal = {World Archaeology},
	Keywords = {Epipalaeolithic; Natu?an; landscape; sedentism},
	Month = {June},
	Owner = {arkygeek},
	Pages = {164-178(15)},
	Timestamp = {2009.02.16},
	Title = {On sedentism' in the Later Epipalaeolithic (Natufian) Levant},
	Url = {http://www.ingentaconnect.com/content/routledg/rwar/2006/00000038/00000002/art00002},
	Volume = {38},
	Year = {2006},
	Bdsk-Url-1 = {http://www.ingentaconnect.com/content/routledg/rwar/2006/00000038/00000002/art00002},
	Bdsk-Url-2 = {http://dx.doi.org/10.1080/00438240600688398}}

