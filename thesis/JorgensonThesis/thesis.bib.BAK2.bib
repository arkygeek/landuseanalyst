@article{Limet1987,
	Abstract = {The civilization of Sumer spanned nearly 3,000 years, and its many
	accomplishments, including the invention of writing, had a profound
	effect on subsequent peoples, not only in Mesopotamia but throughout
	the ancient Near East and beyond. Despite this, Sumer was forgotten
	for thousands of years-until little more than a century ago, when
	archaeological discoveries initiated the challenging process of its
	reconstruction. This paper continues that process, using as its basis
	tablets from the Third Dynasty of Ur, its last period of greatness
	at the end of the second millennium B.C.E. Archaeological Sources
