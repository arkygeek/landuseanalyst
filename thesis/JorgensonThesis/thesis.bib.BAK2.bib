@article{Sherratt1983,
	Abstract = {This paper considers the range of evidence for the secondary uses
	and products of animals: traction, transport, wool and milk. It suggests
	that early farming populations used livestock mainly for meat, and
	that other applications were explored as agriculturalists adapted
	to new conditions, especially in the semi-arid zone. Innovations
	in different parts of the Near East were exchanged and disseminated
	as part of the process leading to urbanisation. Their dispersal affected
	both the steppe belt, which saw a marked increase in population,
	and also temperate Europe, where agriculture was revolutionised by
	more extensive methods of farming and landscape clearance.},
	Author = {Sherratt, Andrew},
	Copyright = {Copyright {\copyright} 1983 Taylor & Francis, Ltd.},
	File = {Sherratt1983.pdf:Sherratt1983.pdf:PDF},
	Issn = {00438243},
	Journal = {World Archaeology},
	Jstor_Articletype = {primary_article},
	Jstor_Formatteddate = {Jun., 1983},
	Jstor_Issuetitle = {Transhumance and Pastoralism},
	Note = {Excellent point wrt development of larger scale dierying depending on the change from small scale horticulture to a larger scale of agriculture. talks about the arrival of the plough and wool-sheep being important. Also, in his conclusions '...the introduction of the plough initiated a more extensive type of agriculture that could support a larger PASTORAL component.' (emphasis mine)},
	Number = {1},
	Pages = {90-104},
	Publisher = {Taylor \& Francis, Ltd.},
	Title = {The secondary exploitation of animals in the Old World},
	Url = {http://www.jstor.org/stable/124640},
