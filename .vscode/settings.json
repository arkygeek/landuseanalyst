{
  // Python Settings
  "python.analysis.extraPaths": [
    "/home/arkygeek/anaconda3/envs/qgis_dev/share/qgis/python",
    "/home/arkygeek/anaconda3/envs/qgis_dev/share/qgis/python/plugins"
  ],
  "python.autoComplete.extraPaths": [
    "/home/arkygeek/anaconda3/envs/qgis_dev/share/qgis/python",
    "/home/arkygeek/anaconda3/envs/qgis_dev/share/qgis/python/plugins"
  ],
  "python.defaultInterpreterPath": "/home/arkygeek/anaconda3/envs/qgis_dev/bin/python",
  // "python.condaPath": "/home/arkygeek/anaconda3/bin/conda",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.shellIntegration.enabled": true,
  "python.analysis.indexing": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.regenerateStdLibIndices": true,
  "python.languageServer": "Default",
  // "python.jediEnabled": false,
  "python.terminal.executeInFileDir": true,
  // "python-envs.terminal.showActivateButton": true,
  "python-envs.defaultEnvManager": "ms-python.python:conda",
  "python-envs.defaultPackageManager": "ms-python.python:conda",

  // Terminal Profile
  "terminal.integrated.profiles.linux": {
    "conda-zsh": {
      "path": "zsh",
      "args": ["-l"],
      "env": {
        "CONDA_DEFAULT_ENV": "qgis_dev"
      }
    }
  },
  "terminal.integrated.defaultProfile.linux": "conda-zsh",

  // Other settings
  "python.analysis.typeCheckingMode": "basic",
  "python-envs.pythonProjects": [],
  "python.formatting.provider": "black",
  "maptz.regionfolder": {
    "[python]": {
      "defaultFoldStartRegex": "\\#[\\s]*#region\\(collapsed\\)[\\s]*(.*)",
      "foldEnd": "# #endregion",
      "foldEndRegex": "\\#[\\s]*#endregion",
      "foldStart": "# #region [NAME]",
      "foldStartRegex": "\\#[\\s]*#region[\\s]*(.*)"
    }
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "entity.name.type.class",
          "keyword",
          "storage.modifier",
          "storage.type.class.js",
          "storage.type.function.js",
          "storage.type.js",
          "keyword.control.import.js",
          "keyword.control.from.js",
          "keyword.control.flow.js",
          "keyword.control.conditional.js",
          "keyword.control.loop.js",
          "keyword.operator.new.js",
          "variable.parameter.function-call.python"
        ],
        "settings": { "fontStyle": "italic" }
      },
      {
        "scope": [
          "invalid",
          "keyword.operator",
          "constant.numeric.css",
          "keyword.other.unit.px.css",
          "constant.numeric.decimal.js",
          "constant.numeric.json",
          "entity.name.type.class.js"
        ],
        "settings": { "fontStyle": "" }
      },
      {
        "scope": [
          "variable.parameter.function-call.python"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#eea781"
        }
      },
      {
        "scope": [
          "entity.name.function.decorator.python",
          "meta.function.decorator.python"
        ],
        "settings": {
          "fontStyle": "italic",
          "foreground": "#a88cd4"
        }
      },
      {
        "scope": [
          "keyword.operator.assignment.python"
        ],
        "settings": {
          "fontStyle": "",
          "foreground": "#fafafa"
        }
      }
    ]
  },
  "editor.fontFamily": "Fira Code iScript",
  "C_Cpp.errorSquiggles": "enabled",
  "files.associations": {
    "qsplitter": "cpp",
    "qheaderview": "cpp"
  },
  "editor.semanticTokenColorCustomizations": {
    "rules": {
      "parameter": {
        "foreground": "#d3745d",
        "fontFamily": "Fira Code iScript",
        "fontStyle": "italic"
      }
    }
  },
  "cmake.ignoreCMakeListsMissing": true,
  "IDX.aI.enableInlineCompletion": true,
  "IDX.aI.enableCodebaseIndexing": true
}